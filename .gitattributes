# Exclude dependency directories from language stats
node_modules/* linguist-vendored
venv/* linguist-vendored
.venv/* linguist-vendored
env/* linguist-vendored
vendor/* linguist-vendored
*.min.js linguist-vendored
*.min.css linguist-vendored

# Frontend files are not the primary language
*.html linguist-documentation=true
*.js linguist-documentation=true
